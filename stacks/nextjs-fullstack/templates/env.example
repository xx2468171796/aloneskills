# ===========================================
# 应用配置
# ===========================================

# 应用 URL
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# 数据库配置
# ===========================================

# PostgreSQL
DATABASE_URL="postgres://user:password@localhost:5432/mydb"

# ===========================================
# 缓存配置
# ===========================================

# Redis
REDIS_URL="redis://localhost:6379"

# ===========================================
# 认证配置
# ===========================================

# Auth.js Secret (至少 32 字符)
AUTH_SECRET="your-auth-secret-must-be-at-least-32-characters"

# OAuth: GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OAuth: Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===========================================
# 对象存储配置 (可选)
# ===========================================

# MinIO / S3
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""
S3_REGION="us-east-1"

# ===========================================
# 邮件配置 (可选)
# ===========================================

# SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ===========================================
# 其他配置
# ===========================================

# Node 环境
NODE_ENV="development"
